{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "display": {
    "separator": " ▐ "
  },

  "logo": {
    "type": "image",
	 "source": "/home/i3t/Imagens/PNGs/pngegg.png",
    "width": 28,
    "height": 14,
    "padding": {
      "right": 5,
      "top": 1
    }
  },

  "modules": [
    {
      "type": "title",
      "key": "user \t",
      "keyColor": "magenta"
    },
    {
      "type": "os",
      "key": "os \t",
      "keyColor": "red"
    },
    {
      "type": "kernel",
      "key": "kernel \t",
      "keyColor": "yellow"
    },
    {
      "type": "packages",
      "key": "package \t",
      "keyColor": "green"
    },
    {
      "type": "shell",
      "key": "shell \t",
      "keyColor": "magenta"
    },
    {
      "type": "wm",
      "key": "wm \t",
      "keyColor": "cyan"
    },
    {
      "type": "terminal",
      "key": "terminal \t",
      "keyColor": "magenta"
    },
    {
      "type": "cpu",
      "key": "cpu \t",
      "keyColor": "red"
    },
    {
      "type": "memory",
      "key": "memory \t",
      "keyColor": "cyan"
    },
    "break",
    "colors"
  ]
}
