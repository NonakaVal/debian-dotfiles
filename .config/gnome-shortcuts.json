[
    {
        "name": "Window Management",
        "shortcuts": [
            {
                "key": "Alt + Space",
                "description": "Window menu"
            },
            {
                "key": "Super + X",
                "description": "Close window"
            },
            {
                "key": "Super + H",
                "description": "Minimize window"
            },
            {
                "key": "Alt + F10",
                "description": "Toggle maximized"
            },
            {
                "key": "Shift + Super + W",
                "description": "Toggle window on all workspaces"
            },
            {
                "key": "Alt + F7",
                "description": "Begin move"
            },
            {
                "key": "Alt + F8",
                "description": "Begin resize"
            },
            {
                "key": "Super + Shift + Down",
                "description": "Move window to monitor below"
            },
            {
                "key": "Super + Shift + Up",
                "description": "Move window to monitor above"
            },
            {
                "key": "Super + Shift + Left",
                "description": "Move window to monitor on left"
            },
            {
                "key": "Super + Shift + Right",
                "description": "Move window to monitor on right"
            }
        ]
    },
    {
        "name": "Window Switching",
        "shortcuts": [
            {
                "key": "Super + Tab",
                "description": "Switch applications"
            },
            {
                "key": "Shift + Super + Tab",
                "description": "Switch applications backward"
            },
            {
                "key": "Alt + Escape",
                "description": "Cycle windows"
            },
            {
                "key": "Shift + Alt + Escape",
                "description": "Cycle windows backward"
            },
            {
                "key": "Alt + F6",
                "description": "Cycle windows in same group"
            }
        ]
    },
    {
        "name": "Workspace Navigation",
        "shortcuts": [
            {
                "key": "Super + Page Down / Ctrl + Alt + Down",
                "description": "Switch to workspace below"
            },
            {
                "key": "Super + Page Up / Ctrl + Alt + Up",
                "description": "Switch to workspace above"
            },
            {
                "key": "Super + Alt + Left / Ctrl + Alt + Left",
                "description": "Switch to workspace on the left"
            },
            {
                "key": "Super + Alt + Right / Ctrl + Alt + Right",
                "description": "Switch to workspace on the right"
            },
            {
                "key": "Super + Home",
                "description": "Switch to first workspace"
            },
            {
                "key": "Super + End",
                "description": "Switch to last workspace"
            }
        ]
    },
    {
        "name": "Move Window to Workspace",
        "shortcuts": [
            {
                "key": "Super + Shift + Page Down / Ctrl + Shift + Alt + Down",
                "description": "Move window to workspace below"
            },
            {
                "key": "Super + Shift + Page Up / Ctrl + Shift + Alt + Up",
                "description": "Move window to workspace above"
            },
            {
                "key": "Super + Shift + Alt + Left / Ctrl + Shift + Alt + Left",
                "description": "Move window to workspace on the left"
            },
            {
                "key": "Super + Shift + Alt + Right / Ctrl + Shift + Alt + Right",
                "description": "Move window to workspace on the right"
            },
            {
                "key": "Super + Shift + Home",
                "description": "Move window to first workspace"
            },
            {
                "key": "Super + Shift + End",
                "description": "Move window to last workspace"
            }
        ]
    },
    {
        "name": "System",
        "shortcuts": [
            {
                "key": "Alt + F2",
                "description": "Run dialog"
            },
            {
                "key": "Alt + F1",
                "description": "Main menu"
            },
            {
                "key": "Super + Space",
                "description": "Switch keyboard layout"
            },
            {
                "key": "Shift + Super + Space",
                "description": "Switch keyboard layout backward"
            },
            {
                "key": "Super + P / XF86Display",
                "description": "Switch monitor configuration"
            },
            {
                "key": "Super + Escape",
                "description": "Restore shortcuts (Wayland)"
            },
            {
                "key": "Ctrl + Shift + Tab / Ctrl + Tab",
                "description": "Switch panels"
            },
            {
                "key": "Ctrl + Alt + Escape",
                "description": "Cycle panels"
            },
            {
                "key": "Super + L",
                "description": "Lock screen"
            },
            {
                "key": "Ctrl + Alt + Delete",
                "description": "Logout"
            },
            {
                "key": "Ctrl + Alt + Super + End",
                "description": "Reboot"
            },
            {
                "key": "Super + ,",
                "description": "Open Settings"
            },
            {
                "key": "Super + E",
                "description": "Open Files (home)"
            },
            {
                "key": "Super + F1",
                "description": "Help"
            },
            {
                "key": "Super + F3",
                "description": "Open browser"
            },
            {
                "key": "Alt + Super + 8",
                "description": "Toggle magnifier"
            },
            {
                "key": "Alt + Super + =",
                "description": "Magnifier zoom in"
            },
            {
                "key": "Alt + Super + -",
                "description": "Magnifier zoom out"
            },
            {
                "key": "Alt + Super + S",
                "description": "Toggle screen reader"
            }
        ]
    },
    {
        "name": "TTY Sessions (Wayland)",
        "shortcuts": [
            {
                "key": "Ctrl + Alt + F1",
                "description": "Switch to session 1"
            },
            {
                "key": "Ctrl + Alt + F2",
                "description": "Switch to session 2"
            },
            {
                "key": "Ctrl + Alt + F3",
                "description": "Switch to session 3"
            },
            {
                "key": "Ctrl + Alt + F4 ~ F12",
                "description": "Switch to session 4–12"
            }
        ]
    },
    {
        "name": "Shell & Launcher",
        "shortcuts": [
            {
                "key": "Super + A",
                "description": "Toggle application view"
            },
            {
                "key": "Super + N",
                "description": "Focus active notification"
            },
            {
                "key": "Ctrl + Super + V",
                "description": "Toggle message tray"
            },
            {
                "key": "Ctrl + Super + S",
                "description": "Toggle quick settings"
            },
            {
                "key": "Super + 1~9",
                "description": "Switch to app by position in dock"
            },
            {
                "key": "Super + Ctrl + 1~9",
                "description": "Open new window of app by position"
            },
            {
                "key": "Super + Alt + Down",
                "description": "Shift overview down"
            },
            {
                "key": "Super + Alt + Up",
                "description": "Shift overview up"
            }
        ]
    },
    {
        "name": "Screenshots & Recording",
        "shortcuts": [
            {
                "key": "Print",
                "description": "Open screenshot UI"
            },
            {
                "key": "Shift + Print",
                "description": "Screenshot (region)"
            },
            {
                "key": "Alt + Print",
                "description": "Screenshot (window)"
            },
            {
                "key": "Ctrl + Shift + Alt + R",
                "description": "Toggle screen recording"
            }
        ]
    },
    {
        "name": "Custom Shortcuts",
        "shortcuts": [
            {
                "key": "Alt + Super + ;",
                "description": "Open keyboard settings",
                "command": "gnome-control-center keyboard"
            },
            {
                "key": "Ctrl + Alt + T",
                "description": "Open Konsole",
                "command": "konsole"
            },
            {
                "key": "Ctrl + Alt + 1",
                "description": "Konsole (profile: Script)",
                "command": "konsole --profile Script"
            },
            {
                "key": "Ctrl + Alt + 2",
                "description": "Konsole (profile: Github)",
                "command": "konsole --profile Github"
            },
            {
                "key": "Super + .",
                "description": "GNOME Characters",
                "command": "flatpak run org.gnome.Characters"
            },
            {
                "key": "Ctrl + Shift + Escape",
                "description": "Mission Center (task manager)",
                "command": "flatpak run io.missioncenter.MissionCenter"
            },
            {
                "key": "Alt + Super + E",
                "description": "Open Dolphin (file manager)",
                "command": "flatpak run org.kde.dolphin"
            },
            {
                "key": "Ctrl + Alt + Super + -",
                "description": "Reset GNOME interface (loginctl)",
                "command": "reset-interface"
            },
            {
                "key": "Ctrl + Alt + Super + End",
                "description": "Reboot system",
                "command": "reboot"
            },
            {
                "key": "Super + [",
                "description": "Enable vertical window list extension",
                "command": "gnome-extensions enable vertical-window-list@student.gitlab.com"
            },
            {
                "key": "Super + ]",
                "description": "Disable vertical window list extension",
                "command": "gnome-extensions disable vertical-window-list@student.gitlab.com"
            },
            {
                "key": "Alt + Super + F",
                "description": "Disable Forge tiling extension",
                "command": "gnome-extensions disable forge@jmmaranan.com"
            },
            {
                "key": "Alt + Super + T",
                "description": "Enable Forge tiling extension",
                "command": "gnome-extensions enable forge@jmmaranan.com"
            }
        ]
    }
]
